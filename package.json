{
  "name": "@devvir/bitmex-api",
  "version": "1.2.1",
  "description": "TypeScript types, Zod schemas, and typed API clients for the BitMEX REST API",
  "author": "devvir",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "default": "./dist/schemas.js"
    },
    "./client/fetch": {
      "types": "./dist/client/fetch.d.ts",
      "default": "./dist/client/fetch.js"
    },
    "./client/axios": {
      "types": "./dist/client/axios.d.ts",
      "default": "./dist/client/axios.js"
    }
  },
  "typesVersions": {
    "*": {
      "types": ["./dist/types.d.ts"],
      "schemas": ["./dist/schemas.d.ts"],
      "client/fetch": ["./dist/client/fetch.d.ts"],
      "client/axios": ["./dist/client/axios.d.ts"]
    }
  },
  "files": [
    "dist",
    "swagger.json",
    "README.md"
  ],
  "scripts": {
    "generate": "node scripts/generate.js",
    "build": "tsc",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  }
}
